#!/usr/bin/env bash
# maude - MyclAude: run claude(1) against a local OpenAI-compatible inference endpoint
#
# Install (one-liner):
#   curl -fsSL https://raw.githubusercontent.com/cloudxabide/devops/main/Files/home_bin_maude \
#     -o ~/bin/maude && chmod +x ~/bin/maude
#
# Or use the built-in install flag:
#   maude --install
#
# Usage: maude [-e HOST:PORT] [-m MODEL] [--install] [-- claude-args...]
#   -e HOST:PORT   endpoint (skip menu; default: localhost:11434)
#   -m MODEL       model name; if omitted, a menu is shown
#   --install      download latest version of this script to ~/bin/maude
#   --             remaining args passed directly to claude

set -euo pipefail

# ── OS detection ──────────────────────────────────────────────────────────────
OS_TYPE=$(uname -s)
case "$OS_TYPE" in
  Darwin) OS="macos" ;;
  Linux)  OS="linux" ;;
  *)      echo "WARNING: unsupported OS '${OS_TYPE}', proceeding anyway" >&2; OS="unknown" ;;
esac

# ── prefer Homebrew bash on macOS (system bash is 3.2; brew bash is 5.x) ─────
# Re-exec with a modern bash if one is available and we're not already using it.
if [[ "$OS" == "macos" && "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  for _brew_bash in \
      /opt/homebrew/bin/bash \
      /usr/local/bin/bash; do
    if [[ -x "$_brew_bash" ]]; then
      exec "$_brew_bash" "$0" "$@"
    fi
  done
  # No Homebrew bash found — continue with system bash (script is 3.2-safe)
  echo "NOTE: using system bash ${BASH_VERSION}; install 'bash' via Homebrew for best results" >&2
fi

# ── known endpoints ───────────────────────────────────────────────────────────
KNOWN_ENDPOINTS=(
  "localhost:11434"
  "10.10.12.251:11434"
)
DEFAULT_ENDPOINT="${KNOWN_ENDPOINTS[0]}"
ENDPOINT=""
MODEL=""
ENDPOINT_EXPLICIT=0
MAUDE_INSTALL_URL="https://raw.githubusercontent.com/cloudxabide/devops/main/Files/home_bin_maude"
MAUDE_INSTALL_DEST="${HOME}/bin/maude"

usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \{0,1\}//'
  exit 1
}

# ── self-install: pre-scan args BEFORE any endpoint/ollama logic ──────────────
# This must run early so --install never touches endpoint selection or ollama.
for _arg in "$@"; do
  if [[ "$_arg" == "--install" ]]; then
    echo "Installing maude to ${MAUDE_INSTALL_DEST} ..."
    mkdir -p "$(dirname "${MAUDE_INSTALL_DEST}")"
    if curl -fsSL "${MAUDE_INSTALL_URL}" -o "${MAUDE_INSTALL_DEST}"; then
      chmod +x "${MAUDE_INSTALL_DEST}"
      echo "Installed successfully: ${MAUDE_INSTALL_DEST}"
    else
      echo "ERROR: download failed from ${MAUDE_INSTALL_URL}" >&2
      exit 1
    fi
    exit 0
  fi
done

while [[ $# -gt 0 ]]; do
  case "$1" in
    -e|--endpoint) ENDPOINT="$2"; ENDPOINT_EXPLICIT=1; shift 2 ;;
    -m|--model)    MODEL="$2";    shift 2 ;;
    -h|--help)     usage ;;
    --)            shift; break ;;
    *)             break ;;
  esac
done

# ── endpoint selection ────────────────────────────────────────────────────────
if [[ $ENDPOINT_EXPLICIT -eq 0 ]]; then
  echo "Select Ollama endpoint:"
  for i in "${!KNOWN_ENDPOINTS[@]}"; do
    marker=""
    [[ "${KNOWN_ENDPOINTS[$i]}" == "$DEFAULT_ENDPOINT" ]] && marker=" (default)"
    printf "  %2d) %s%s\n" $((i+1)) "${KNOWN_ENDPOINTS[$i]}" "$marker"
  done
  echo ""
  read -rp "Select endpoint [1-${#KNOWN_ENDPOINTS[@]}] (Enter for default): " EP_CHOICE

  if [[ -z "$EP_CHOICE" ]]; then
    ENDPOINT="$DEFAULT_ENDPOINT"
  elif ! [[ "$EP_CHOICE" =~ ^[0-9]+$ ]] || \
       (( EP_CHOICE < 1 )) || (( EP_CHOICE > ${#KNOWN_ENDPOINTS[@]} )); then
    echo "Invalid selection." >&2
    exit 1
  else
    ENDPOINT="${KNOWN_ENDPOINTS[$((EP_CHOICE-1))]}"
  fi
fi

BASE_URL="http://${ENDPOINT}"

# ── ollama availability check ─────────────────────────────────────────────────
_ollama_ready() {
  curl -sf --max-time 3 "${BASE_URL}/api/tags" >/dev/null 2>&1
}

if ! _ollama_ready; then
  echo ""
  echo "WARNING: Ollama not reachable at ${ENDPOINT}" >&2
  read -rp "Would you like to start Ollama? [y/N]: " START_ANSWER
  case "${START_ANSWER,,}" in
    y|yes)
      if [[ "$OS" == "macos" ]]; then
        echo "Starting Ollama (macOS native)..."
        # Try the macOS app bundle first; fall back to CLI daemon
        if open -a Ollama 2>/dev/null; then
          echo "  Launched Ollama.app — waiting for it to become ready..."
        else
          echo "  'open -a Ollama' failed; trying 'ollama serve' in background..."
          ollama serve >/dev/null 2>&1 &
        fi
      else
        # Linux: assume open-webui / docker compose stack
        echo "Starting Ollama (Linux/Docker)..."
        if docker start ollama 2>/dev/null; then
          echo "  Started existing 'ollama' container."
        elif docker compose up -d ollama 2>/dev/null; then
          echo "  Started 'ollama' via docker compose."
        else
          echo "ERROR: could not start Ollama container. Start it manually and retry." >&2
          exit 1
        fi
      fi

      echo ""
      echo -n "Waiting for Ollama to become ready"
      for _i in $(seq 1 20); do
        sleep 2
        if _ollama_ready; then
          echo " ready."
          break
        fi
        echo -n "."
        if (( _i == 20 )); then
          echo ""
          echo "ERROR: Ollama still not reachable after 40 seconds." >&2
          exit 1
        fi
      done
      ;;
    *)
      echo "Aborting." >&2
      exit 1
      ;;
  esac
fi

# ── model selection ───────────────────────────────────────────────────────────
if [[ -z "$MODEL" ]]; then
  echo ""
  echo "Querying ${BASE_URL}/v1/models ..."
  MODELS_JSON=$(curl -sf "${BASE_URL}/v1/models") || {
    echo "ERROR: could not reach ${BASE_URL}/v1/models" >&2
    exit 1
  }

  # Extract model IDs — works with both Ollama and standard OpenAI-style responses
  # Use a while-read loop instead of mapfile: macOS ships bash 3.2 (no mapfile)
  MODELS=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && MODELS+=("$line")
  done < <(
    echo "$MODELS_JSON" | \
      python3 -c "
import sys, json
data = json.load(sys.stdin)
# handle {models:[{name:...}]} (Ollama /api/tags) and {data:[{id:...}]} (OpenAI)
items = data.get('data') or data.get('models') or []
for m in items:
    print(m.get('id') or m.get('name') or '')
" | grep -v '^$' | sort
  )

  if [[ ${#MODELS[@]} -eq 0 ]]; then
    echo "ERROR: no models found at ${BASE_URL}/v1/models" >&2
    exit 1
  fi

  echo ""
  echo "Available models at ${ENDPOINT}:"
  for i in "${!MODELS[@]}"; do
    printf "  %2d) %s\n" $((i+1)) "${MODELS[$i]}"
  done
  echo ""
  read -rp "Select model [1-${#MODELS[@]}]: " CHOICE

  if ! [[ "$CHOICE" =~ ^[0-9]+$ ]] || \
     (( CHOICE < 1 )) || (( CHOICE > ${#MODELS[@]} )); then
    echo "Invalid selection." >&2
    exit 1
  fi

  MODEL="${MODELS[$((CHOICE-1))]}"
fi

echo ""
echo "Model:    ${MODEL}"
echo "Endpoint: ${BASE_URL}"
echo ""

# ── environment setup ─────────────────────────────────────────────────────────
export ANTHROPIC_BASE_URL="${BASE_URL}"
export ANTHROPIC_AUTH_TOKEN="ollama"   # satisfies claude(1) auth check for local endpoints
export ANTHROPIC_API_KEY=""            # must be empty string (not unset) to avoid auth conflict
# Map all Claude tier models to the selected local model so claude(1) does not
# attempt to fall back to a different Anthropic model.
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${MODEL}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${MODEL}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${MODEL}"
export DISABLE_TELEMETRY=1

# ── launch claude ─────────────────────────────────────────────────────────────
exec claude --model "${MODEL}" "$@"
