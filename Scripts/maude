#!/usr/bin/env bash
# maude - MyclAude: run claude(1) against a local OpenAI-compatible inference endpoint
#
# Install (one-liner):
#   curl -fsSL https://raw.githubusercontent.com/cloudxabide/maude-code/refs/heads/main/Scripts/maude \
#     -o /tmp/maude && install -m 0755 /tmp/maude ~/bin/maude && rm -f /tmp/maude
#
# Or use the built-in install flag:
#   maude --install
#
# Usage: maude [-e HOST:PORT] [-m MODEL] [-v] [--install] [--update] [-- claude-args...]
#   -e HOST:PORT   endpoint (skip menu; default: localhost:11434)
#   -m MODEL       model name; if omitted, a menu is shown
#   -v             verbose: show setup details and post-session stats
#                  (wall time, token counts, output token rate)
#   --install      download latest version of this script to ~/bin/maude
#   --update       replace the running script with the latest from the git repo
#   --             remaining args passed directly to claude
#
# State file: ~/.local/state/maude/maude.state (auto-created on first run)
#   KNOWN_ENDPOINTS=(...)          – list of endpoints shown in the menu
#   DEFAULT_ENDPOINT="host:port"   – default endpoint (pre-selected in menu)
#   MAUDE_INSTALL_URL="url"        – URL used by --install
#   MAUDE_INSTALL_DEST="path"      – destination used by --install
#
# Config file: ~/.config/maude.conf (optional, sourced as bash)
#   DEFAULT_ENDPOINT="host:port"   – override state-file default endpoint
#   DEFAULT_MODEL="model-name"     – skip model menu and use this model
#   EXTRA_ENDPOINTS=(...)          – extra endpoints appended to the menu

set -euo pipefail

# ── OS detection ──────────────────────────────────────────────────────────────
OS_TYPE=$(uname -s)
case "$OS_TYPE" in
  Darwin) OS="macos" ;;
  Linux)  OS="linux" ;;
  *)      echo "WARNING: unsupported OS '${OS_TYPE}', proceeding anyway" >&2; OS="unknown" ;;
esac

# ── prefer Homebrew bash on macOS (system bash is 3.2; brew bash is 5.x) ─────
# Re-exec with a modern bash if one is available and we're not already using it.
if [[ "$OS" == "macos" && "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  for _brew_bash in \
      /opt/homebrew/bin/bash \
      /usr/local/bin/bash; do
    if [[ -x "$_brew_bash" ]]; then
      exec "$_brew_bash" "$0" "$@"
    fi
  done
  # No Homebrew bash found — continue with system bash (script is 3.2-safe)
  echo "NOTE: using system bash ${BASH_VERSION}; install 'bash' via Homebrew for best results" >&2
fi

# ── state file (~/.local/state/maude/maude.state) ─────────────────────────────
# Created automatically on first run with built-in defaults; edit to customise.
# Variables defined here: KNOWN_ENDPOINTS, DEFAULT_ENDPOINT,
#   MAUDE_INSTALL_URL, MAUDE_INSTALL_DEST
MAUDE_STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/maude"
MAUDE_STATE_FILE="${MAUDE_STATE_DIR}/maude.state"

if [[ ! -f "$MAUDE_STATE_FILE" ]]; then
  mkdir -p "$MAUDE_STATE_DIR"
  cat > "$MAUDE_STATE_FILE" << 'STATEOF'
# maude state file — created automatically; edit to customise
KNOWN_ENDPOINTS=(
  "localhost:11434"
  "10.10.12.251:11434"
)
DEFAULT_ENDPOINT="localhost:11434"
MAUDE_INSTALL_URL="https://raw.githubusercontent.com/cloudxabide/maude-code/refs/heads/main/Scripts/maude"
MAUDE_INSTALL_DEST="${HOME}/bin/maude"
STATEOF
fi
# shellcheck source=/dev/null
source "$MAUDE_STATE_FILE"

# ── runtime vars (not persisted) ──────────────────────────────────────────────
ENDPOINT=""
MODEL=""
ENDPOINT_EXPLICIT=0
VERBOSE=0

# ── config file (~/.config/maude.conf) ────────────────────────────────────────
# Recognised variables (set any/all):
#   DEFAULT_ENDPOINT="host:port"   – overrides built-in default endpoint
#   DEFAULT_MODEL="model-name"     – skip model menu and use this model
#   EXTRA_ENDPOINTS=(...)          – extra endpoints appended to the menu
EXTRA_ENDPOINTS=()
MAUDE_CONF="${XDG_CONFIG_HOME:-${HOME}/.config}/maude.conf"
if [[ -f "$MAUDE_CONF" ]]; then
  # shellcheck source=/dev/null
  source "$MAUDE_CONF"
fi
[[ ${#EXTRA_ENDPOINTS[@]} -gt 0 ]] && KNOWN_ENDPOINTS+=("${EXTRA_ENDPOINTS[@]}")
_deduped=()
while IFS= read -r _ep; do
  [[ -n "$_ep" ]] && _deduped+=("$_ep")
done < <(printf '%s\n' "${KNOWN_ENDPOINTS[@]}" | sort -u)
KNOWN_ENDPOINTS=("${_deduped[@]}")
unset _deduped _ep

usage() {
  awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
  exit 1
}

_maude_splash() {
  [[ -t 1 ]] || return 0
  local b r cy yw
  b=$(tput bold 2>/dev/null)     || b=''
  r=$(tput sgr0 2>/dev/null)     || r=''
  cy=$(tput setaf 6 2>/dev/null) || cy=''
  yw=$(tput setaf 3 2>/dev/null) || yw=''
  printf '\n'
  printf '%s  ╔══════════════════════════════════╗\n'        "$cy"
  printf '%s  ║%-34s║\n'                                     "$cy" ""
  printf '  ║%s%-34s%s║\n'  "${b}${cy}" "  M A U D E  ·  MyClaude" "${r}${cy}"
  printf '%s  ║%-34s║\n'                                     "$cy" "  now with AI *"
  printf '%s  ║%-34s║\n'                                     "$cy" ""
  printf '  ╚══════════════════════════════════╝%s\n'        "$r"
  printf '      %s* built with Claude%s\n\n'                 "$yw" "$r"
}

# ── self-install: pre-scan args BEFORE any endpoint/ollama logic ──────────────
# This must run early so --install never touches endpoint selection or ollama.
_maude_fetch_and_place() {
  local dest="$1" label="$2"
  echo "${label} maude at ${dest} ..."
  mkdir -p "$(dirname "${dest}")"
  local tmp
  tmp=$(mktemp)
  if curl -fsSL "${MAUDE_INSTALL_URL}" -o "${tmp}"; then
    install -m 0755 "${tmp}" "${dest}"
    rm -f "${tmp}"
    echo "${label%ing} successfully: ${dest}"
  else
    rm -f "${tmp}"
    echo "ERROR: download failed from ${MAUDE_INSTALL_URL}" >&2
    exit 1
  fi
}

for _arg in "$@"; do
  case "$_arg" in
    --install)
      _maude_fetch_and_place "${MAUDE_INSTALL_DEST}" "Installing"
      exit 0
      ;;
    --update)
      # Update the currently-running script in-place.
      # Resolves the real path so symlinks point to the refreshed binary.
      _running=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")
      _maude_fetch_and_place "${_running}" "Updating"
      exit 0
      ;;
  esac
done

while [[ $# -gt 0 ]]; do
  case "$1" in
    -e|--endpoint) ENDPOINT="$2"; ENDPOINT_EXPLICIT=1; shift 2 ;;
    -m|--model)    MODEL="$2";    shift 2 ;;
    -v|--verbose)  VERBOSE=1;     shift ;;
    -h|--help)     usage ;;
    --)            shift; break ;;
    *)             break ;;
  esac
done
# Apply config DEFAULT_MODEL if -m was not given
[[ -z "$MODEL" && -n "${DEFAULT_MODEL:-}" ]] && MODEL="${DEFAULT_MODEL}"

# ── endpoint selection ────────────────────────────────────────────────────────
_maude_splash
if [[ $ENDPOINT_EXPLICIT -eq 0 ]]; then
  echo "Select Ollama endpoint:"
  for i in "${!KNOWN_ENDPOINTS[@]}"; do
    marker=""
    [[ "${KNOWN_ENDPOINTS[$i]}" == "$DEFAULT_ENDPOINT" ]] && marker=" (default)"
    printf "  %2d) %s%s\n" $((i+1)) "${KNOWN_ENDPOINTS[$i]}" "$marker"
  done
  echo ""
  read -rp "Select endpoint [1-${#KNOWN_ENDPOINTS[@]}] (Enter for default): " EP_CHOICE

  if [[ -z "$EP_CHOICE" ]]; then
    ENDPOINT="$DEFAULT_ENDPOINT"
  elif ! [[ "$EP_CHOICE" =~ ^[0-9]+$ ]] || \
       (( EP_CHOICE < 1 )) || (( EP_CHOICE > ${#KNOWN_ENDPOINTS[@]} )); then
    echo "Invalid selection." >&2
    exit 1
  else
    ENDPOINT="${KNOWN_ENDPOINTS[$((EP_CHOICE-1))]}"
  fi
fi

BASE_URL="http://${ENDPOINT}"

# ── ollama availability check ─────────────────────────────────────────────────
_ollama_ready() {
  curl -sf --max-time 3 "${BASE_URL}/api/tags" >/dev/null 2>&1
}

if ! _ollama_ready; then
  echo ""
  echo "WARNING: Ollama not reachable at ${ENDPOINT}" >&2
  read -rp "Would you like to start Ollama? [y/N]: " START_ANSWER
  case "${START_ANSWER,,}" in
    y|yes)
      if [[ "$OS" == "macos" ]]; then
        echo "Starting Ollama (macOS native)..."
        # Try the macOS app bundle first; fall back to CLI daemon
        if open -a Ollama 2>/dev/null; then
          echo "  Launched Ollama.app — waiting for it to become ready..."
        else
          echo "  'open -a Ollama' failed; trying 'ollama serve' in background..."
          ollama serve >/dev/null 2>&1 &
        fi
      else
        # Linux: assume open-webui / docker compose stack
        echo "Starting Ollama (Linux/Docker)..."
        if docker start ollama 2>/dev/null; then
          echo "  Started existing 'ollama' container."
        elif docker compose up -d ollama 2>/dev/null; then
          echo "  Started 'ollama' via docker compose."
        else
          echo "ERROR: could not start Ollama container. Start it manually and retry." >&2
          exit 1
        fi
      fi

      echo ""
      echo -n "Waiting for Ollama to become ready"
      for _i in $(seq 1 20); do
        sleep 2
        if _ollama_ready; then
          echo " ready."
          break
        fi
        echo -n "."
        if (( _i == 20 )); then
          echo ""
          echo "ERROR: Ollama still not reachable after 40 seconds." >&2
          exit 1
        fi
      done
      ;;
    *)
      echo "Aborting." >&2
      exit 1
      ;;
  esac
fi

# ── model selection ───────────────────────────────────────────────────────────
if [[ -z "$MODEL" ]]; then
  echo ""
  echo "Querying ${BASE_URL}/v1/models ..."
  MODELS_JSON=$(curl -sf "${BASE_URL}/v1/models") || {
    echo "ERROR: could not reach ${BASE_URL}/v1/models" >&2
    exit 1
  }

  # Extract model IDs — works with both Ollama and standard OpenAI-style responses
  # Use a while-read loop instead of mapfile: macOS ships bash 3.2 (no mapfile)
  MODELS=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && MODELS+=("$line")
  done < <(
    if command -v jq >/dev/null 2>&1; then
      echo "$MODELS_JSON" | \
        jq -r '(.data // .models // [])[] | (.id // .name // "") | select(length > 0)'
    else
      echo "$MODELS_JSON" | \
        python3 -c "
import sys, json
data = json.load(sys.stdin)
items = data.get('data') or data.get('models') or []
for m in items:
    print(m.get('id') or m.get('name') or '')
" | grep -v '^$'
    fi | sort
  )

  if [[ ${#MODELS[@]} -eq 0 ]]; then
    echo "ERROR: no models found at ${BASE_URL}/v1/models" >&2
    exit 1
  fi

  echo ""
  echo "Available models at ${ENDPOINT}:"
  for i in "${!MODELS[@]}"; do
    printf "  %2d) %s\n" $((i+1)) "${MODELS[$i]}"
  done
  echo ""
  read -rp "Select model [1-${#MODELS[@]}]: " CHOICE

  if ! [[ "$CHOICE" =~ ^[0-9]+$ ]] || \
     (( CHOICE < 1 )) || (( CHOICE > ${#MODELS[@]} )); then
    echo "Invalid selection." >&2
    exit 1
  fi

  MODEL="${MODELS[$((CHOICE-1))]}"
fi

echo ""
echo "Model:    ${MODEL}"
echo "Endpoint: ${BASE_URL}"
echo ""

# ── environment setup ─────────────────────────────────────────────────────────
export ANTHROPIC_BASE_URL="${BASE_URL}"
export ANTHROPIC_AUTH_TOKEN="ollama"   # satisfies claude(1) auth check for local endpoints
export ANTHROPIC_API_KEY=""            # must be empty string (not unset) to avoid auth conflict
# Map all Claude tier models to the selected local model so claude(1) does not
# attempt to fall back to a different Anthropic model.
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${MODEL}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${MODEL}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${MODEL}"
export DISABLE_TELEMETRY=1

# ── launch claude ─────────────────────────────────────────────────────────────
if [[ $VERBOSE -eq 0 ]]; then
  exec claude --model "${MODEL}" "$@"
fi

# Verbose path: wrap session with wall-clock timing and post-session token stats.
# Token data is read from claude's session JSONL in ~/.claude/projects/ after exit.
_SESSION_MARKER=$(mktemp)
_SESSION_START=$(date +%s)

claude --model "${MODEL}" "$@"
_RC=$?

_SESSION_END=$(date +%s)
_DURATION=$((_SESSION_END - _SESSION_START))

_cwd_slug=$(pwd | sed 's|/|-|g')
_proj_dir="${HOME}/.claude/projects/${_cwd_slug}"
_session_jsonl=$(find "${_proj_dir}" -name "*.jsonl" -newer "${_SESSION_MARKER}" 2>/dev/null | tail -1)
rm -f "${_SESSION_MARKER}"

echo ""
echo "── maude session stats ──────────────────────────"
printf "  Wall time:     %dm %02ds\n" $((_DURATION / 60)) $((_DURATION % 60))

if [[ -n "$_session_jsonl" ]]; then
  MAUDE_JSONL="$_session_jsonl" MAUDE_DURATION="$_DURATION" python3 << 'PYEOF'
import json, os

path     = os.environ['MAUDE_JSONL']
duration = int(os.environ['MAUDE_DURATION'])
total_in = total_out = total_cr = total_cc = turns = 0

with open(path) as f:
    for line in f:
        obj   = json.loads(line)
        msg   = obj.get('message')
        usage = msg.get('usage') if isinstance(msg, dict) else None
        if usage:
            total_in  += usage.get('input_tokens', 0)
            total_out += usage.get('output_tokens', 0)
            total_cr  += usage.get('cache_read_input_tokens', 0)
            total_cc  += usage.get('cache_creation_input_tokens', 0)
            turns     += 1

total = total_in + total_out + total_cr + total_cc
rate  = total_out / duration if duration > 0 and total_out > 0 else 0

print(f"  Turns:         {turns}")
print(f"  Input tokens:  {total_in:,}")
print(f"  Output tokens: {total_out:,}")
if total_cr or total_cc:
    print(f"  Cache read:    {total_cr:,}")
    print(f"  Cache write:   {total_cc:,}")
print(f"  Total tokens:  {total:,}")
if rate > 0:
    print(f"  Output rate:   {rate:.1f} tok/s")
PYEOF
else
  echo "  (no token data — local endpoint or session not persisted)"
fi

echo "─────────────────────────────────────────────────"
exit $_RC
